{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mockexam",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "production": {
      "vars": {
        "SUPABASE_URL": "",
        "SUPABASE_ANON_KEY": ""
      }
    }
  }
}
