{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mockexam",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1": {
    "bindings": [
      {
        "binding": "examDB",
        "database_name": "mock_exam",
        "database_id": "6528bc19-69df-4337-8326-7f5ac2d2bc6a"
      }
    ]
  }
}
